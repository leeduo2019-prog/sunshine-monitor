# 阳光平台监控 - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ⚠️ 不要将 .env 文件提交到版本控制！

# 钉钉机器人配置
# Webhook 地址：钉钉群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# 加签密钥：钉钉机器人安全设置中选择"加签"方式
DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxx
# 请求超时时间（秒）
DINGTALK_TIMEOUT=10

# 爬虫配置
TARGET_URL=https://www.qdygcg.com/web-portal/#/trade-info?purchaseProjectType=&noticeType=&tradePatternId=&publishTime=
MAX_PAGES=10
PAGE_LOAD_TIMEOUT=120
ELEMENT_WAIT_TIMEOUT=30
PAGE_NAVIGATION_TIMEOUT=15
MAX_RETRIES=3
RETRY_DELAY=5

# 筛选关键词（逗号分隔）
FILTER_KEYWORDS=造价,审计,决算,财务,预算
